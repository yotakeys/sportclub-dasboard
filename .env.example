# ====================================
# Database Configuration
# ====================================

# For Docker deployment (no SSL needed)
POSTGRES_URL=postgres://sportclub:your_secure_password@db:5432/sportclub
POSTGRES_SSL=false

# For external databases (e.g., Supabase, Neon) that require SSL
# POSTGRES_URL=postgres://user:password@host:5432/database
# POSTGRES_SSL=true

# Docker Compose specific
POSTGRES_USER=sportclub
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DATABASE=sportclub

# ====================================
# Authentication
# ====================================

# Generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here
AUTH_URL=http://localhost:3000/api/auth

# ====================================
# Admin User (used during database seeding)
# ====================================

ADMIN_EMAIL=admin@sportclub.com
ADMIN_PASSWORD=changeme123